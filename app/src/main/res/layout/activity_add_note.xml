<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ================= TOP BAR ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_primary"
            android:contentDescription="Back"
            android:scaleType="centerInside" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textColor="@color/accent_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- ================= CONTENT ================= -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <!-- TITLE -->
            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:hint="Title"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:inputType="textCapSentences"
                android:paddingBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/border_subtle"
                android:layout_marginBottom="16dp" />

            <!-- CONTENT -->
            <EditText
                android:id="@+id/et_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:hint="Start writing..."
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:lineSpacingMultiplier="1.7"
                android:minHeight="300dp" />

        </LinearLayout>

    </ScrollView>

    <!-- ================= ACTION BAR ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <!-- IMAGE -->
        <ImageButton
            android:id="@+id/btn_image"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/accent_primary"
            android:contentDescription="Image" />

        <!-- MIC -->
        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_mic"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/accent_primary"
            android:contentDescription="Voice input" />

        <!-- NOTE TYPE (FIXED POSITION) -->
        <ImageButton
            android:id="@+id/btn_note_type"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_tag"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/accent_primary"
            android:contentDescription="Note Type" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ASK AI -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ask_ai"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Ask AI"
            android:textColor="@color/white"
            android:textSize="13sp"
            app:backgroundTint="@color/accent_primary"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_ai_avatar"
            app:iconTint="@color/white"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:elevation="0dp" />

    </LinearLayout>

</LinearLayout>