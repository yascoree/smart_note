<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/background">

        <!-- AI Orb -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/gradient_purple_blue">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_ai_avatar"
                android:tint="@color/text_primary" />

        </FrameLayout>

        <!-- Title and Status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Note AI"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@color/accent_purple"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Active"
                    android:textSize="11sp"
                    android:textColor="@color/accent_purple" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/border" />

    <!-- Suggestion Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                android:id="@+id/chip_summarize"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="6dp"
                android:text="Summarize"
                android:textSize="11sp"
                    app:chipBackgroundColor="@color/surface"
                    app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="0.5dp"
                    android:textColor="@color/text_secondary" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_improve_writing"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="6dp"
                android:text="Improve writing"
                android:textSize="11sp"
                app:chipBackgroundColor="@color/surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="0.5dp"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_find_ideas"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="6dp"
                android:text="Find ideas"
                android:textSize="11sp"
                app:chipBackgroundColor="@color/surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="0.5dp"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_translate"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="6dp"
                android:text="Translate"
                android:textSize="11sp"
                app:chipBackgroundColor="@color/surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="0.5dp"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_make_list"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Make list"
                android:textSize="11sp"
                app:chipBackgroundColor="@color/surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="0.5dp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Chat Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="100dp"
        android:scrollbars="vertical" />

    <!-- Input Bar (Pinned at Bottom) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/background">


        <!-- Input Field -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="0.5dp">

                <EditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:hint="Ask anything about your notes..."
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:maxLines="1"
                android:textSize="14sp" />

        </com.google.android.material.card.MaterialCardView>


        <!-- Send Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:layout_marginEnd="8dp"
            app:cornerRadius="24dp"
            app:icon="@drawable/ic_mic"
            app:iconSize="22dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:backgroundTint="@color/surface"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:iconTint="@color/accent_purple"
            app:elevation="0dp"
            android:contentDescription="Record" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:layout_marginStart="8dp"
            app:cornerRadius="24dp"
            app:icon="@drawable/ic_send"
            app:iconSize="22dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:backgroundTint="@color/accent_primary"
            app:strokeWidth="0dp"
            app:iconTint="@color/text_inverse"
            app:elevation="0dp"
            android:contentDescription="Send" />

    </LinearLayout>

</LinearLayout>