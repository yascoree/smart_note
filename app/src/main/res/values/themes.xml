<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Smart_note" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/text_inverse</item>
        <item name="colorPrimaryContainer">@color/accent_purple_bg</item>
        <item name="colorOnPrimaryContainer">@color/accent_purple</item>
        <item name="colorSecondary">@color/accent_teal</item>
        <item name="colorOnSecondary">@color/text_inverse</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_secondary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/border</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:enforceNavigationBarContrast">false</item>
